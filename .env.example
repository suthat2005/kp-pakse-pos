# Server Port Configuration
PORT=5173

# Application Environment Mode (development / production)
NODE_ENV=production

# Database Settings (Template configurations)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=kp_pakse_pos

# Firebase Admin Configuration
FIREBASE_KEY_PATH=./firebase-key.json

# API access token — shared secret required in the Authorization header for /api/* routes.
# CHANGE THIS to a long random value in production. The client build must use the same value via VITE_API_TOKEN.
API_TOKEN=change-me-to-a-long-random-secret

# Token embedded in the client bundle (must match API_TOKEN). Note: this is visible to anyone
# with access to the app, so it only gates access, it is not a true secret.
VITE_API_TOKEN=change-me-to-a-long-random-secret

# CORS: comma-separated list of allowed origins, or '*' to allow any origin.
# Restrict this to your POS domain/LAN origin in production, e.g. http://192.168.1.50:5173
ALLOWED_ORIGINS=*
