model Category {
  id          String    @id @default(cuid())
  legacyId    String?   @unique
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id])
  name        String
  icon        String?
  type        String    @default("product")
  parentId    String?
  parent      Category? @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  path        String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@unique([businessId, name, parentId])
}

model Brand {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id])
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@unique([businessId, name])
}

model Product {
  id          String    @id @default(cuid())
  legacyId    String?   @unique
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id])
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  brandId     String?
  brand       Brand?    @relation(fields: [brandId], references: [id])
  name        String
  description String?
  sku         String?
  barcode     String?
  qrCode      String?
  unit        String    @default("piece")
  basePrice   Decimal   @default(0)
  costPrice   Decimal   @default(0)
  averageCost Decimal   @default(0)
  latestCost  Decimal   @default(0)
  minStock    Decimal   @default(0)
  weight      Decimal?
  taxRate     Decimal   @default(0)
  isActive    Boolean   @default(true)
  showOnline  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  variants              ProductVariant[]
  images                ProductImage[]
  prices                ProductPrice[]
  barcodes              Barcode[]
  suppliers             ProductSupplier[]
  inventories           Inventory[]
  inventoryTxs          InventoryTransaction[]
  orderItems            OrderItem[]
  productionOut         ProductionHistory[]
  lots                  Lot[]
  serials               SerialNumber[]
  stockTransferItems    StockTransferItem[]
  stockCountItems       StockCountItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  purchaseReceiveItems  PurchaseReceiveItem[]
  cartItems             CartItem[]
  reviews               Review[]
  recommendationsAsBase    Recommendation[] @relation("BaseProduct")
  recommendationsAsRelated Recommendation[] @relation("RelatedProduct")
  stockAlerts           StockAlert[]

  @@unique([businessId, sku])
  @@unique([businessId, barcode])
}

model ProductVariant {
  id          String    @id @default(cuid())
  legacyId    String?   @unique
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  sku         String?
  barcode     String?
  options     String?   // JSON: {color:"gold",size:"M"}
  price       Decimal   @default(0)
  cost        Decimal   @default(0)
  weight      Decimal?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  images                ProductImage[]
  prices                ProductPrice[]
  barcodes              Barcode[]
  inventories           Inventory[]
  inventoryTxs          InventoryTransaction[]
  orderItems            OrderItem[]
  lots                  Lot[]
  serials               SerialNumber[]
  stockTransferItems    StockTransferItem[]
  stockCountItems       StockCountItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  purchaseReceiveItems  PurchaseReceiveItem[]
  cartItems             CartItem[]
  stockAlerts           StockAlert[]

  @@unique([productId, name])
}

model ProductImage {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  mediaId     String?
  media       Media?          @relation(fields: [mediaId], references: [id])
  url         String
  order       Int             @default(0)
  isPrimary   Boolean         @default(false)
  createdAt   DateTime        @default(now())
}

model ProductPrice {
  id              String          @id @default(cuid())
  productId       String
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  priceList       PriceListType   @default(retail)
  customerGroupId String?
  customerTierId  String?
  customerTier    CustomerTier?   @relation(fields: [customerTierId], references: [id])
  minQty          Decimal         @default(1)
  price           Decimal
  currency        String          @default("LAK")
  validFrom       DateTime?
  validTo         DateTime?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Barcode {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  code        String
  type        String          @default("ean13")
  isPrimary   Boolean         @default(false)
  createdAt   DateTime        @default(now())

  @@unique([productId, code])
}

model Supplier {
  id          String    @id @default(cuid())
  legacyId    String?   @unique
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id])
  name        String
  contact     String?
  phone       String?
  email       String?
  address     String?
  taxId       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  productSuppliers ProductSupplier[]
  purchaseOrders   PurchaseOrder[]
  expenses         Expense[]
  receives         PurchaseReceive[]
}

model ProductSupplier {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierSku  String?
  cost         Decimal  @default(0)
  minOrderQty  Decimal  @default(0)
  leadTimeDays Int?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([productId, supplierId])
}
